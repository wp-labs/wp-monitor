extern mod cfm { git = "https://github.com/galaxy-operators/cfm-gxl.git", branch = "${GXL_CHANNEL:develop}" }
mod  envs {
  env default {
    root = "./" ;
  }
}
mod main   : ver_adm {

  #[auto_load(entry)]
    flow _entry : ver.use {
    }

  #[auto_load(exit)]
    flow ver.set_cargo_ver | @_set_ver {
        gx.cmd ("cargo update")
        gx.cmd ("cargo check")
    }


}
