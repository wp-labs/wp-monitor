extern mod vfm { path = "@{PATH}"; }

mod  envs {
  env default {
     ROOT= "./";
  }
}
mod main   : ver_adm {

#[auto_load(entry)]
  flow _entry : ver.use {
  }

#[auto_load(exit)]
  flow _set_ver |  _syn_cargo | _syn_compose {
  }
  flow _syn_cargo | ver.syn_file {
    SYN_FILE = "${ENV_ROOT}/Cargo.toml";
  }
  flow _syn_compose | ver.syn_file {
    SYN_FILE = "${ENV_ROOT}/install/docker/docker-compose.yml";
  }
}
